{% extends 'base.html.twig' %}

{% block title %}Categorie {{ category.name }}{% endblock %}

{% block body %}
    <div class="page-shell">
        <div class="page-header">
            <div>
                <h1 class="page-title">{{ category.name }}</h1>
                <p class="page-subtitle">{{ category.description ?: 'Articles de cette categorie.' }}</p>
            </div>
            <a href="{{ path('app_post_index') }}" class="btn btn-outline-light">Toutes les categories</a>
        </div>

        <div class="content-card">
            <div class="list-group">
                {% for post in posts %}
                    <a href="{{ path('app_post_show', {id: post.id}) }}" class="list-group-item list-group-item-action rounded-3">
                        <h5 class="mb-1">{{ post.title }}</h5>
                        <small class="text-muted">
                            {{ post.author.firstName }} {{ post.author.lastName }} - {{ post.publishedAt|date('d/m/Y H:i') }}
                        </small>
                        <div class="mt-1">
                            <span class="badge text-bg-danger">Likes: {{ post.likes|length }}</span>
                        </div>
                    </a>
                {% else %}
                    <div class="empty-state">Aucun article publie dans cette categorie.</div>
                {% endfor %}
            </div>

            <div class="mt-3 d-flex justify-content-center">
                {{ knp_pagination_render(posts) }}
            </div>
        </div>
    </div>
{% endblock %}
