{% extends 'base.html.twig' %}

{% block title %}Articles{% endblock %}

{% block body %}
    <div class="page-shell">
        <div class="page-header">
            <div>
                <h1 class="page-title">Liste des articles</h1>
                <p class="page-subtitle">Parcours toutes les publications du blog Dragon Ball Z.</p>
            </div>
        </div>
        <div class="content-card mb-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label for="q" class="form-label">Recherche</label>
                    <input id="q" type="text" name="q" class="form-control" value="{{ filters.q }}" placeholder="Titre ou contenu">
                </div>
                <div class="col-md-3">
                    <label for="category" class="form-label">Categorie</label>
                    <select id="category" name="category" class="form-select">
                        <option value="">Toutes</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {{ filters.category == category.id ? 'selected' : '' }}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="sort" class="form-label">Tri</label>
                    <select id="sort" name="sort" class="form-select">
                        <option value="latest" {{ filters.sort == 'latest' ? 'selected' : '' }}>Plus recents</option>
                        <option value="oldest" {{ filters.sort == 'oldest' ? 'selected' : '' }}>Plus anciens</option>
                        <option value="title" {{ filters.sort == 'title' ? 'selected' : '' }}>Titre A-Z</option>
                        <option value="popular" {{ filters.sort == 'popular' ? 'selected' : '' }}>Populaires</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button class="btn btn-primary w-100" type="submit">Filtrer</button>
                    <a class="btn btn-outline-light w-100" href="{{ path('app_post_index') }}">Reset</a>
                </div>
            </form>
        </div>
        <div class="content-card">
            <div class="list-group">
                {% for post in posts %}
                    <a href="{{ path('app_post_show', {id: post.id}) }}" class="list-group-item list-group-item-action rounded-3">
                        <h5 class="mb-1">{{ post.title }}</h5>
                        <small class="text-muted">{{ post.category.name }} - {{ post.author.firstName }} {{ post.author.lastName }}</small>
                        <div class="mt-1">
                            <span class="badge text-bg-danger">Likes: {{ post.likes|length }}</span>
                        </div>
                    </a>
                {% else %}
                    <div class="empty-state">Aucun article disponible.</div>
                {% endfor %}
            </div>
            <div class="mt-3 d-flex justify-content-center">
                {{ knp_pagination_render(posts) }}
            </div>
        </div>
    </div>
{% endblock %}
