{% extends 'base.html.twig' %}

{% block title %}Articles{% endblock %}

{% block body %}
    <div class="page-shell">
        <div class="page-header">
            <div>
                <h1 class="page-title">Articles par categorie</h1>
            </div>
            <a href="{{ path('app_post_work_analysis') }}" class="btn btn-outline-warning">Analyse de l'oeuvre</a>
        </div>
        <div class="row g-4">
            {% for category in categories %}
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 shonen-card">
                        {% if category.picture %}
                            <img src="{{ category.picture }}" class="card-img-top category-card-img" alt="{{ category.name }}">
                        {% else %}
                            <div class="category-card-placeholder d-flex align-items-center justify-content-center">
                                <span class="text-muted">Image a definir</span>
                            </div>
                        {% endif %}
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">{{ category.name }}</h5>
                            <a href="{{ path('app_post_category', {id: category.id}) }}" class="btn btn-warning fw-bold mt-auto">Voir la categorie</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="content-card tight empty-state">
                    Aucune categorie disponible.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
