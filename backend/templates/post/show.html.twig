{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
    <div class="page-shell">
        <article class="content-card">
            <h1 class="page-title mb-2">{{ post.title }}</h1>
            <p class="page-subtitle">{{ post.category.name }} - {{ post.publishedAt|date('d/m/Y H:i') }}</p>
            <div class="d-flex align-items-center gap-3 mb-3">
                <span class="badge text-bg-danger">Likes: {{ post.likes|length }}</span>
                {% if app.user %}
                    {% set hasLiked = post.likes|filter(like => like.user and like.user.id == app.user.id)|length > 0 %}
                    <form method="post" action="{{ path('app_post_like_toggle', {id: post.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_like_' ~ post.id) }}">
                        <button class="btn btn-sm {{ hasLiked ? 'btn-outline-danger' : 'btn-danger' }}">
                            {{ hasLiked ? 'Retirer le like' : 'Liker cet article' }}
                        </button>
                    </form>
                {% endif %}
            </div>
            {% if post.picture %}
                <img src="{{ post.picture }}" class="article-cover my-4" alt="{{ post.title }}">
            {% endif %}
            <div class="lh-lg">{{ post.content|nl2br }}</div>
        </article>

        <section class="content-card">
            <h2 class="section-title">Commentaires</h2>
            {% if app.user %}
                {% set hasPendingUserComment = post.comments|filter(comment => comment.author and comment.author.id == app.user.id and comment.status == 'pending')|length > 0 %}
                {% if hasPendingUserComment %}
                    <div class="alert alert-warning">
                        L administrateur n a pas encore valide votre commentaire.
                    </div>
                {% endif %}
            {% endif %}
            {% for comment in post.comments %}
                {% if comment.status == 'approved' or is_granted('ROLE_ADMIN') %}
                    <div class="card comment-card mb-3">
                        <div class="card-body">
                            <p class="mb-1">{{ comment.content }}</p>
                            <small class="text-muted">
                                {{ comment.author.firstName }} {{ comment.author.lastName }} - {{ comment.createdAt|date('d/m/Y H:i') }}
                            </small>
                        </div>
                    </div>
                {% endif %}
            {% else %}
                <p class="empty-state">Aucun commentaire.</p>
            {% endfor %}
        </section>

        {% if app.user %}
            <section class="content-card form-shell">
                <h3 class="section-title">Ajouter un commentaire</h3>
                {{ form_start(commentForm) }}
                {{ form_row(commentForm.content) }}
                <button class="btn btn-primary">Envoyer</button>
                {{ form_end(commentForm) }}
            </section>
        {% else %}
            <div class="content-card tight">
                <div class="alert alert-warning mb-0">
                    Vous devez vous connecter pour publier un commentaire.
                    <a href="{{ path('app_login') }}" class="alert-link">Se connecter</a>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
