{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublie{% endblock %}

{% block body %}
    <div class="page-shell">
        <div class="content-card form-shell">
            <h1 class="page-title mb-3">Reinitialiser le mot de passe</h1>
            <p class="page-subtitle">Saisis ton email pour recevoir un lien de reinitialisation.</p>
            {{ form_start(requestForm) }}
            {{ form_row(requestForm.email) }}
            <button class="btn btn-primary">Envoyer le lien</button>
            {{ form_end(requestForm) }}
        </div>
    </div>
{% endblock %}
