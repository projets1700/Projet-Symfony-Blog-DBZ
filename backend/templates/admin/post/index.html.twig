{% extends 'base.html.twig' %}

{% block title %}Gestion des articles{% endblock %}

{% block body %}
    <div class="page-shell">
        <div class="page-header">
            <div>
                <h1 class="page-title">Gestion des articles</h1>
                <p class="page-subtitle">Ajoute, modifie et organise les articles du blog.</p>
            </div>
            <a href="{{ path('app_admin_post_new') }}" class="btn btn-primary">Nouvel article</a>
        </div>
        <div class="content-card">
            <div class="table-wrap">
                <table class="table table-striped">
                    <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Catégorie</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for post in posts %}
                        <tr>
                            <td>{{ post.title }}</td>
                            <td>{{ post.category.name }}</td>
                            <td>
                                {% if post.isApproved %}
                                    <span class="badge text-bg-success">Publie</span>
                                {% else %}
                                    <span class="badge text-bg-secondary">En attente</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_admin_post_edit', {id: post.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                                {% if not post.isApproved %}
                                    <form method="post" action="{{ path('app_admin_post_validate', {id: post.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('validate_post_' ~ post.id) }}">
                                        <button class="btn btn-sm btn-success">Publier</button>
                                    </form>
                                {% endif %}
                                <form method="post" action="{{ path('app_admin_post_delete', {id: post.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                                    <button class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4">Aucun article.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="mt-3 d-flex justify-content-center">
                {{ knp_pagination_render(posts) }}
            </div>
        </div>
    </div>
{% endblock %}
