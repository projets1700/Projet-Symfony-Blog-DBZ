{% extends 'base.html.twig' %}

{% block title %}Modération des commentaires{% endblock %}

{% block body %}
    <div class="page-shell">
        <div class="page-header">
            <div>
                <h1 class="page-title">Modération des commentaires</h1>
                <p class="page-subtitle">Valide ou rejette les commentaires dans une interface plus lisible.</p>
            </div>
        </div>
        <div class="content-card">
            <div class="table-wrap">
                <table class="table table-hover">
                    <thead>
                    <tr>
                        <th>Categorie</th>
                        <th>Sous-categorie</th>
                        <th>Article</th>
                        <th>Auteur</th>
                        <th>Contenu</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for comment in comments %}
                        {% set category = comment.post.category %}
                        {% set parentCategory = category ? category.parent : null %}
                        <tr>
                            <td>{{ parentCategory ? parentCategory.name : (category ? category.name : 'Non classe') }}</td>
                            <td>{{ parentCategory ? category.name : '-' }}</td>
                            <td>{{ comment.post.title }}</td>
                            <td>{{ comment.author.firstName }} {{ comment.author.lastName }}</td>
                            <td>{{ comment.content }}</td>
                            <td>
                                {% if comment.status == 'approved' %}
                                    Approuve
                                {% elseif comment.status in ['rejected', 'deleted'] %}
                                    Rejete
                                {% else %}
                                    En attente
                                {% endif %}
                            </td>
                            <td>
                                <form method="post" action="{{ path('app_admin_comment_validate', {id: comment.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('validate_comment_' ~ comment.id) }}">
                                    <button class="btn btn-sm btn-success">Valider</button>
                                </form>
                                <form method="post" action="{{ path('app_admin_comment_reject', {id: comment.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reject_comment_' ~ comment.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Rejeter</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7">Aucun commentaire.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="mt-3 d-flex justify-content-center">
                {{ knp_pagination_render(comments) }}
            </div>
        </div>
    </div>
{% endblock %}
