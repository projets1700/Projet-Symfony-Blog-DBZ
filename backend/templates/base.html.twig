<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Blog Dragon Ball Z{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>
<body
    class="theme-shonen"
    data-auto-refresh="{% block auto_refresh_enabled %}true{% endblock %}"
    data-auto-refresh-interval="{% block auto_refresh_interval %}30000{% endblock %}"
>
{% block shenron_effects %}
{% endblock %}
{% if block('shenron_effects') is not empty %}
<div class="dragon-scene" aria-hidden="true">
    <div class="dragon-balls">
        {{ block('shenron_effects') }}
    </div>
    <div class="shenron-wrap">
        <div class="shenron-flash"></div>
        <div class="summon-lightning bolt-1"></div>
        <div class="summon-lightning bolt-2"></div>
        <div class="summon-lightning bolt-3"></div>
        <div class="summon-lightning bolt-4"></div>
        <div class="summon-lightning bolt-5"></div>
        <div class="shenron-illustration"></div>
    </div>
</div>
{% endif %}
<nav class="shonen-navbar">
    <div class="container side-nav-topbar">
        <a class="navbar-brand fw-bold text-uppercase shonen-brand" href="{{ path('app_home') }}">Blog Dragon Ball Z</a>
        <button
            type="button"
            class="btn btn-outline-warning side-nav-toggle"
            data-side-nav-toggle
            aria-expanded="false"
            aria-controls="side-navigation"
        >
            Menu
        </button>
    </div>
</nav>

<div class="side-nav-backdrop" data-side-nav-backdrop></div>
<aside id="side-navigation" class="side-nav-panel" aria-hidden="true">
    <div class="side-nav-header">
        <span class="side-nav-title">Navigation</span>
        <button type="button" class="btn btn-sm btn-outline-light" data-side-nav-close>Fermer</button>
    </div>

    <div class="side-nav-body">
        <div class="side-nav-section">
            <a class="side-nav-link" href="{{ path('app_post_index') }}">Articles</a>
            <a class="side-nav-link" href="{{ path('app_post_work_analysis') }}">Analyse de l'oeuvre</a>
            {% if is_granted('ROLE_ADMIN') %}
                <a class="side-nav-link" href="{{ path('app_admin_dashboard') }}">Tableau de bord</a>
                <a class="side-nav-link" href="{{ path('app_admin_post_index') }}">Gestion des articles</a>
                <a class="side-nav-link" href="{{ path('app_admin_category_index') }}">Gestion des categories</a>
                <a class="side-nav-link" href="{{ path('app_admin_user_index') }}">Gestion des utilisateurs</a>
                <a class="side-nav-link" href="{{ path('app_admin_comment_index') }}">Moderation des commentaires</a>
            {% endif %}
        </div>

        <div class="side-nav-section">
            {% if is_granted('ROLE_ADMIN') %}
                <span class="badge text-bg-warning text-dark">Administrateur</span>
            {% elseif app.user %}
                <span class="badge text-bg-info text-dark">Utilisateur connecte</span>
            {% else %}
                <span class="badge text-bg-secondary">Visiteur</span>
            {% endif %}
        </div>

        {% if app.user %}
            <div class="side-nav-section">
                <a class="side-nav-link side-nav-profile" href="{{ path('app_profile') }}" title="Mon profil">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture }}" alt="{{ app.user.firstName }}" class="rounded-circle border border-warning" style="width: 42px; height: 42px; object-fit: cover;">
                    {% else %}
                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning text-dark fw-bold border border-warning" style="width: 42px; height: 42px;">
                            {{ app.user.firstName|first }}{{ app.user.lastName|first }}
                        </span>
                    {% endif %}
                    <span>Mon profil</span>
                </a>
                {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
                    <a class="side-nav-link" href="{{ path('app_home', {'_switch_user': '_exit'}) }}">Quitter mode utilisateur</a>
                {% endif %}
                <a class="side-nav-link" href="{{ path('app_logout') }}">Deconnexion</a>
            </div>
        {% else %}
            <div class="side-nav-section">
                <a class="side-nav-link" href="{{ path('app_login') }}">Connexion</a>
                <a class="side-nav-link" href="{{ path('app_register') }}">Inscription</a>
            </div>
        {% endif %}
    </div>
</aside>

<main class="container py-4 site-shell">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}
    {% block body %}{% endblock %}
</main>
</body>
</html>
