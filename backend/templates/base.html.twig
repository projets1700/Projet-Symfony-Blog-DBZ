<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Blog Dragon Ball Z{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>
<body
    class="theme-shonen"
    data-auto-refresh="{% block auto_refresh_enabled %}true{% endblock %}"
    data-auto-refresh-interval="{% block auto_refresh_interval %}30000{% endblock %}"
>
<div class="dragon-scene" aria-hidden="true">
    <div class="dragon-balls">
        <span class="dragon-ball stars-1"></span>
        <span class="dragon-ball stars-2"></span>
        <span class="dragon-ball stars-3"></span>
        <span class="dragon-ball stars-4"></span>
        <span class="dragon-ball stars-5"></span>
        <span class="dragon-ball stars-6"></span>
        <span class="dragon-ball stars-7"></span>
    </div>
    <div class="shenron-wrap">
        <div class="shenron-flash"></div>
        <div class="summon-lightning bolt-1"></div>
        <div class="summon-lightning bolt-2"></div>
        <div class="summon-lightning bolt-3"></div>
        <div class="summon-lightning bolt-4"></div>
        <div class="summon-lightning bolt-5"></div>
        <div class="shenron-illustration"></div>
    </div>
</div>
<nav class="navbar navbar-expand-lg shonen-navbar">
    <div class="container">
        <a class="navbar-brand fw-bold text-uppercase shonen-brand" href="{{ path('app_home') }}">Blog Dragon Ball Z</a>
        <div class="collapse navbar-collapse show">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_post_index') }}">Articles</a></li>
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_post_index') }}">Gestion des articles</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_user_index') }}">Gestion des utilisateurs</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_admin_comment_index') }}">Modération des commentaires</a></li>
                {% endif %}
            </ul>
            <ul class="navbar-nav">
                <li class="nav-item d-flex align-items-center me-2">
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="badge text-bg-warning text-dark">Administrateur</span>
                    {% elseif app.user %}
                        <span class="badge text-bg-info text-dark">Utilisateur connecte</span>
                    {% else %}
                        <span class="badge text-bg-secondary">Visiteur</span>
                    {% endif %}
                </li>
                {% if app.user %}
                    <li class="nav-item d-flex align-items-center me-2">
                        <a class="nav-link p-0" href="{{ path('app_profile') }}" title="Mon profil">
                            {% if app.user.profilePicture %}
                                <img src="{{ app.user.profilePicture }}" alt="{{ app.user.firstName }}" class="rounded-circle border border-warning" style="width: 42px; height: 42px; object-fit: cover;">
                            {% else %}
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning text-dark fw-bold border border-warning" style="width: 42px; height: 42px;">
                                    {{ app.user.firstName|first }}{{ app.user.lastName|first }}
                                </span>
                            {% endif %}
                        </a>
                    </li>
                    {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home', {'_switch_user': '_exit'}) }}">Quitter mode utilisateur</a>
                        </li>
                    {% elseif is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home', {'_switch_user': 'fan@dbz.local'}) }}">Tester en utilisateur</a>
                        </li>
                    {% endif %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a></li>
                {% else %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">Connexion</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">Inscription</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4 site-shell">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}
    {% block body %}{% endblock %}
</main>
</body>
</html>
